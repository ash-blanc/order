# Order Environment Variables

# TinyFish API (for Discord, X scraping)
ORDER_TINYFISH_API_KEY=your-tinyfish-api-key

# GitHub Personal Access Token
ORDER_GITHUB_TOKEN=your-github-pat

# LLM API Keys (set one)
ORDER_OPENAI_API_KEY=your-openai-key
ORDER_OPENROUTER_API_KEY=your-openrouter-key

# Model to use
ORDER_LLM_MODEL=openrouter/nova-pro

# Data directory
ORDER_DATA_DIR=~/.order

# CORS — set to your Vercel frontend URL in production
# ORDER_FRONTEND_URL=https://your-app.vercel.app